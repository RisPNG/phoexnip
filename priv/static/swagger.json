    "Permission": {
      "description": "A permission object representing user permissions based on the sitemap. In short what the user can access in the system",
      "example": {
        "children": [
          {
            "permission": 16,
            "sequence": 30,
            "sitemap_code": "INV1",
            "sitemap_level": 1,
            "sitemap_name": "Product Management",
            "sitemap_parent": "INV",
            "sitemap_url": "product"
          }
        ],
        "permission": 16,
        "sequence": 20,
        "sitemap_code": "INV",
        "sitemap_level": 0,
        "sitemap_name": "Inventory",
        "sitemap_url": ""
      },
      "properties": {
        "children": {
          "description": "Nested permissions for child sitemaps (this can only be for level 0)",
          "items": {
            "$ref": "#/definitions/Permission"
          },
          "type": "array"
        },
        "permission": {
          "description": "User permission level",
          "type": "integer"
        },
        "sequence": {
          "description": "Display order sequence",
          "type": "integer"
        },
        "sitemap_code": {
          "description": "Sitemap code",
          "type": "string"
        },
        "sitemap_level": {
          "description": "Sitemap level",
          "type": "integer"
        },
        "sitemap_name": {
          "description": "Sitemap name",
          "type": "string"
        },
        "sitemap_parent": {
          "description": "Parent sitemap code",
          "type": "string"
        },
        "sitemap_url": {
          "description": "Sitemap URL",
          "type": "string"
        }
      },
      "required": [
        "permission",
        "sequence",
        "sitemap_level",
        "sitemap_name",
        "sitemap_code"
      ],
      "title": "Users Permissions",
      "type": "object"
    },
